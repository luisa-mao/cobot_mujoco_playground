<mujoco model="Omni_Kinova_Cobot">
  <compiler angle="radian" autolimits="true" />
  <option integrator="implicitfast" iterations="1" ls_iterations="0" cone="elliptic" impratio="10" timestep="0.002" />
  
  <visual>
    <global offwidth="1920" offheight="1080" /> 
    <scale forcewidth="0.1" contactwidth="0.3" contactheight="0.1" framelength="0.5" framewidth="0.01" />
  </visual>

  <default>
    <default class="visual">
      <geom type="mesh" contype="0" conaffinity="0" group="2" rgba="0.75294 0.75294 0.75294 1" />
    </default>
    <default class="collision">
      <geom type="capsule" group="3" contype="2" conaffinity="1" />
    </default>
    <default class="environment">
      <geom contype="1" conaffinity="2" />
    </default>
    <default class="large_actuator">
      <position kp="2000" kv="100" forcerange="-105 105" />
    </default>
    <default class="small_actuator">
      <position kp="500" kv="50" forcerange="-52 52" />
    </default>
    <site size="0.001" rgba="0.5 0.5 0.5 0.3" group="4" />
  </default>

  <asset>
    <mesh name="base_link" file="kinova_gen3/assets/base_link.stl" />
    <mesh name="shoulder_link" file="kinova_gen3/assets/shoulder_link.stl" />
    <mesh name="half_arm_1_link" file="kinova_gen3/assets/half_arm_1_link.stl" />
    <mesh name="half_arm_2_link" file="kinova_gen3/assets/half_arm_2_link.stl" />
    <mesh name="forearm_link" file="kinova_gen3/assets/forearm_link.stl" />
    <mesh name="spherical_wrist_1_link" file="kinova_gen3/assets/spherical_wrist_1_link.stl" />
    <mesh name="spherical_wrist_2_link" file="kinova_gen3/assets/spherical_wrist_2_link.stl" />
    <mesh name="bracelet_with_vision_link" file="kinova_gen3/assets/bracelet_with_vision_link.stl" />
    <mesh name="cobot_base_link" file="cobot_base/assets/base_link.stl" />
  </asset>

  <worldbody>
    <light pos="0 0 1.5" dir="0 0 -1" directional="true" />
    <geom name="floor" type="box" size="2 2 0.01" pos="0 0 -0.01" rgba="1 1 1 1" />
    
    <body name="omni_chassis" pos="0 0 0.1">
      <!-- <joint name="base_x" type="slide" axis="1 0 0" damping="20" />
      <joint name="base_y" type="slide" axis="0 1 0" damping="20" />
      <joint name="base_yaw" type="hinge" axis="0 0 1" damping="10" /> -->
      <geom type="mesh" mesh="cobot_base_link" mass="20.0" rgba="0.2 0.2 0.2 0.5" euler="1.571 0 0" contype="0" conaffinity="0" />
      <geom type="box" size="0.25 0.35 0.15" pos="0 0 0.1" class="collision" />

      <body name="base_link" pos="0 .025 0.469">
        <geom class="visual" mesh="base_link" />
        <body name="shoulder_link" pos="0 0 0.15643" quat="0 1 0 0">
          <joint name="joint_1" />
          <geom class="visual" mesh="shoulder_link" name="shoulder_link_visual"/>
          <body name="half_arm_1_link" pos="0 0.005375 -0.12838" quat="1 1 0 0">
            <joint name="joint_2" range="-2.24 2.24" />
            <geom class="visual" mesh="half_arm_1_link" name="half_arm_1_link_visual"/>
            <body name="half_arm_2_link" pos="0 -0.21038 -0.006375" quat="1 -1 0 0">
              <joint name="joint_3" />
              <geom class="visual" mesh="half_arm_2_link" name="half_arm_2_link_visual"/>
              <body name="forearm_link" pos="0 0.006375 -0.21038" quat="1 1 0 0">
                <joint name="joint_4" range="-2.57 2.57" />
                <geom class="visual" mesh="forearm_link" name="forearm_link_visual"/>
                <body name="spherical_wrist_1_link" pos="0 -0.20843 -0.006375" quat="1 -1 0 0">
                  <joint name="joint_5" />
                  <geom class="visual" mesh="spherical_wrist_1_link" name="spherical_wrist_1_link_visual"/>
                  <body name="spherical_wrist_2_link" pos="0 0.00017505 -0.10593" quat="1 1 0 0">
                    <joint name="joint_6" range="-2.09 2.09" />
                    <geom class="visual" mesh="spherical_wrist_2_link" name="spherical_wrist_2_link_visual"/>
                    <body name="end_effector" pos="0 -0.10593 -0.00017505" quat="1 -1 0 0">
                      <joint name="joint_7" />
                      <geom class="visual" mesh="bracelet_with_vision_link" />
                      <geom name="ee_collision" type="capsule" size="0.03" fromto="0 0 0 0 0 -0.15" rgba="0.8 0.2 0.2 1" />
                      <site name="pinch_site" pos="0 0 -0.15" quat="0 1 0 0" group="3" />
                      <camera name="handcam" pos="0 0 0.05" quat="1 0 0 0" />
                    </body>
                  </body>
                </body>
              </body>
            </body>
          </body>
        </body>
      </body>
    </body>
    <body name="target_visual" mocap="true">
      <geom type="sphere" size="0.03" rgba="0 1 0 0.5" contype="0" conaffinity="0"/>
    </body>
    <camera name="sideview" pos="4.0 0 0.8" quat="0.5 0.5 0.5 0.5" />
    <camera name="topdown" pos="0 0 2.0" quat="1 0 0 0" />
  </worldbody>


  <actuator>
    <!-- <velocity name="cmd_vel_x" joint="base_x" kv="5000" ctrlrange="-10 10" />
    <velocity name="cmd_vel_y" joint="base_y" kv="5000" ctrlrange="-10 10" />
    <velocity name="cmd_vel_yaw" joint="base_yaw" kv="5000" ctrlrange="-3.14 3.14" /> -->
    <position class="large_actuator" name="joint_1" joint="joint_1" />
    <position class="large_actuator" name="joint_2" joint="joint_2" ctrlrange="-2.24 2.24" />
    <position class="large_actuator" name="joint_3" joint="joint_3" />
    <position class="large_actuator" name="joint_4" joint="joint_4" ctrlrange="-2.57 2.57" />
    <position class="small_actuator" name="joint_5" joint="joint_5" />
    <position class="small_actuator" name="joint_6" joint="joint_6" ctrlrange="-2.09 2.09" />
    <position class="small_actuator" name="joint_7" joint="joint_7" />
  </actuator>

  <keyframe>
    <key name="home" qpos="0 0.26 3.14 -2.26 0 0.95 1.57" />
  </keyframe>
</mujoco>